datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Portfolio {
  id           Int    @id @default(autoincrement())
  symbol       String
  addedPrice   Float
  currentPrice Float
}

model Watchlist {
  id           Int    @id @default(autoincrement())
  symbol       String
  addedPrice   Float
  currentPrice Float
}
